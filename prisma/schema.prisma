// Prisma Schema for Atoms Demo with Keyword Indexing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 项目表
model Project {
  id          String   @id @default(cuid())
  title       String   @default("新项目")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  messages     Message[]
  codeVersions CodeVersion[]
  symbols      Symbol[]
  
  @@map("projects")
}

// 消息表
model Message {
  id        String   @id @default(cuid())
  role      String   // 'user' | 'assistant'
  content   String
  createdAt DateTime @default(now())
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("messages")
}

// 代码版本表
model CodeVersion {
  id          String   @id @default(cuid())
  html        String   @default("")
  css         String   @default("")
  js          String   @default("")
  version     Int      @default(1)
  description String?
  createdAt   DateTime @default(now())
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("code_versions")
}

// 符号表 (Symbol Table) - 关键词索引核心
model Symbol {
  id        String   @id @default(cuid())
  name      String   // 函数名、变量名、类名
  type      String   // 'function' | 'variable' | 'class' | 'interface' | 'type' | 'event'
  snippet   String   // 代码片段
  line      Int      @default(0) // 所在行号
  file      String   @default("main") // 文件路径，如 "src/components/Button.tsx"
  fileId    String?  // 关联的File ID（可选）
  keywords  String[] // 关键词数组（用于全文搜索）
  signature String?  // 函数签名或接口定义（用于TypeScript）
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // 索引优化
  @@index([projectId, name])
  @@index([projectId, type])
  @@index([keywords])
  @@index([file])
  @@index([fileId])
  @@map("symbols")
}

// 用户表
model User {
  id          String   @id // 雪花算法生成的ID
  username    String   @unique // 用户名（唯一）
  passwordHash String   // MD5加盐后的密码
  salt        String   // 盐值
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([username])
  @@map("users")
}

// Session 表 - 会话管理
model Session {
  id          String   @id @default(uuid())
  sessionId  String   @unique // UUID session ID
  userId     String   // 用户ID
  projectId  String   // 项目ID
  projectName String?  // 项目名称
  status     String   @default("active") // 'active' | 'completed' | 'failed'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // 元数据（JSON存储）
  metadata   String?  // JSON string for metadata
  
  // 对话历史和生成的代码（JSON存储，之前存在 Redis，现在存在 PostgreSQL）
  conversationHistory String?  // JSON string for ConversationMessage[]
  generatedCode       String?  // JSON string for { html, css, js, description }
  context            String?  // JSON string for context object
  
  files      File[]   // 关联的文件
  
  @@index([sessionId])
  @@index([userId])
  @@index([userId, updatedAt])
  @@index([projectId])
  @@index([status])
  @@index([updatedAt])
  @@map("sessions")
}

// File 表 - 文件存储
model File {
  id          String   @id @default(uuid())
  sessionId   String   // Session ID
  session     Session  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  
  path        String   // 文件路径，如 "index.html", "src/components/Button.tsx"
  name        String   // 文件名
  type        String   // 'text' | 'binary'
  content     String?  // 文本内容（TEXT类型）
  binaryData  Bytes?   // 二进制内容（BYTEA类型）
  mimeType    String?  // MIME类型，如 "text/html", "image/png"
  size        Int      @default(0) // 文件大小（字节）
  
  // 关联到项目（通过session.projectId）
  projectId   String?  // 项目ID（从Session获取）
  
  // 新增字段：支持自愈式 Code Agent
  symbolHash  String?  // 代码内容的 Hash，用于判断是否需要重新索引符号
  lastValidation Json? // 存储上次沙箱校验的结果（tsc 报错信息等）
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([sessionId])
  @@index([sessionId, path])
  @@index([projectId])
  @@index([symbolHash]) // 索引 symbolHash 用于快速查找
  @@unique([sessionId, path]) // 确保同一session下路径唯一
  @@map("files")
}

// ChatMessage 表 - 聊天记录
model ChatMessage {
  id          String   @id @default(uuid())
  sessionId   String   // Session ID
  userId      String   // 用户ID（用户消息）或固定的AI ID（AI消息）
  context     String   // 消息内容
  createdAt   DateTime @default(now())
  
  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@map("chat_messages")
}
